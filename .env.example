# ──────────────────────────────────────────────────────────────────────────
# LinePay Cite — environment configuration
#
# ⚠️  TESTNET ONLY. Every contract and address here targets Circle's Arc
#     TESTNET. All USDC is TEST USDC (or the bundled MockUSDC faucet token) with
#     no real-world value. Never point these at a mainnet.
#
# Copy to .env (root) and apps/web/.env.local. Everything works in SIMULATE
# mode out of the box; fill the live values only when you go on-chain (testnet).
# ──────────────────────────────────────────────────────────────────────────

# ── Payments mode ──────────────────────────────────────────────────────────
# "simulate" (default) settles in a local ledger — no keys, no network.
# "live" signs authorizations and settles real USDC via Circle Gateway on Arc.
PAYMENTS_MODE=simulate

# ── Arc testnet (live mode) ────────────────────────────────────────────────
# Provision with the Canteen ARC CLI:
#   uv tool install git+https://github.com/the-canteen-dev/ARC-cli
# Docs: arc-node.thecanteenapp.com  ·  docs.arc.network
# CONFIRM these from the ARC CLI / Circle console — the official SDK also
# resolves them from the named chain "arcTestnet" (CIRCLE_CHAIN below).
ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_CHAIN_ID=5042002                # Arc testnet chain id
ARC_NETWORK_CAIP2=eip155:5042002    # CAIP-2 network id (Circle x402 "network")
USDC_ADDRESS=0x3600000000000000000000000000000000000000   # ERC-20 USDC on Arc testnet (6 decimals)

# ── Circle Gateway / Agent Stack (live mode) ───────────────────────────────
# Circle CLI:  npm install -g @circle-fin/cli   (Node >= 20.18.2)
# Official SDK: npm install @circle-fin/x402-batching  (GatewayClient / BatchFacilitatorClient)
# Docs: developers.circle.com/gateway/nanopayments · developers.circle.com/agent-stack
CIRCLE_API_KEY=
CIRCLE_CHAIN=arcTestnet                              # named chain for the SDK
CIRCLE_GATEWAY_URL=https://gateway-api-testnet.circle.com   # Settle x402 API host
GATEWAY_WALLET_ADDRESS=0x0077777d7EBA4688BDeF3E311b846F25870A19B9   # GatewayWalletBatched (EIP-712 verifyingContract, testnet)

# Wallets (Circle Agent Stack). Names mirror circlefin/arc-nanopayments.
# The BUYER is the autonomous agent; the SELLER receives payments.
BUYER_ADDRESS=
BUYER_PRIVATE_KEY=                  # funded with TEST USDC via the Circle CLI faucet
SELLER_ADDRESS=
SELLER_PRIVATE_KEY=
# Back-compat aliases used by the simulate-mode flows:
AGENT_WALLET_ADDRESS=0x000000000000000000000000000000000000A9e1
AGENT_WALLET_PRIVATE_KEY=
READER_WALLET_ADDRESS=0x000000000000000000000000000000000000dead

# ── Revenue split contract (optional; falls back to direct creator pay) ─────
# Deploy with: npm run contracts:deploy   (needs DEPLOYER_PRIVATE_KEY below)
REVENUE_SPLIT_ADDRESS=
# Where every creator's sales are paid on-chain. Resolution order:
# REVENUE_SPLIT_ADDRESS -> CREATOR_PAYOUT_ADDRESS -> the creator's own wallet
# -> a burn fallback. Set this to a dummy "send to nowhere" address for demos,
# or to your own wallet to keep the testnet USDC. Leave blank to pay creators
# directly from their stored wallet.
CREATOR_PAYOUT_ADDRESS=
PLATFORM_ADDRESS=0x000000000000000000000000000000000000bEEF
REFERRER_ADDRESS=0x000000000000000000000000000000000000FEE5
DEPLOYER_PRIVATE_KEY=

# ── Agent reasoning (LLM) ──────────────────────────────────────────────────
# The buyer agent reasons with an LLM via LangChain. All optional — with no key
# it falls back to a deterministic heuristic brain so the demo always runs.
# Provider is auto-selected: Groq if GROQ_API_KEY is set, else Anthropic.
# Force one with AGENT_PROVIDER=groq | anthropic.
AGENT_PROVIDER=

# Groq — FREE + fast. Get a key at https://console.groq.com/keys
GROQ_API_KEY=                       # never commit a real key — this is an example file
GROQ_MODEL=llama-3.3-70b-versatile

# Anthropic (Claude) — alternative provider.
ANTHROPIC_API_KEY=
AGENT_MODEL=claude-opus-4-8

# ── App ────────────────────────────────────────────────────────────────────
APP_BASE_URL=http://localhost:3000
DATABASE_PATH=./linepay.db

# ── On-chain marketplace (RainbowKit/Wagmi + AgentMarketplace) ─────────────
# NEXT_PUBLIC_* are exposed to the browser. Leave blank to keep the on-chain
# /market page in "not configured" mode; the x402 /read + agent flows still work.
NEXT_PUBLIC_ARC_CHAIN_ID=5042002
NEXT_PUBLIC_ARC_RPC_URL=https://rpc.testnet.arc.network
NEXT_PUBLIC_ARC_EXPLORER_URL=https://testnet.arcscan.app
NEXT_PUBLIC_WC_PROJECT_ID=          # WalletConnect id — cloud.walletconnect.com
NEXT_PUBLIC_USDC_ADDRESS=           # ERC-20 USDC (or MockUSDC) on Arc
NEXT_PUBLIC_MARKETPLACE_ADDRESS=    # deployed AgentMarketplace address
# (DEPLOYER_PRIVATE_KEY for Hardhat deploys is set in the revenue-split section above)

# ── Off-chain content storage for the marketplace ──────────────────────────
# With PINATA_JWT set, published content is encrypted + pinned to IPFS; without
# it, encrypted ciphertext is stored locally in SQLite (MVP). Either way the
# plaintext is only released by /api/reveal after an on-chain access check.
PINATA_JWT=
PINATA_GATEWAY=https://gateway.pinata.cloud/ipfs
# Key used to AES-256-GCM encrypt marketplace content. CHANGE THIS in prod.
CONTENT_ENCRYPTION_KEY=change-me-to-a-long-random-secret